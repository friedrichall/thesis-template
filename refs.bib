  author = {Ma, Xianzheng and Smart, Brandon and Bhalgat, Yash and Chen, Shuai and Li, Xinghui and Ding, Jian and Gu, Jindong and Chen, Dave Zhenyu and Peng, Songyou and Bian, Jia-Wang and Torr, Philip H. and Pollefeys, Marc and Nie{\ss}ner, Matthias and Reid, Ian D. and Chang, Angel X. and Laina, Iro and Prisacariu, Victor Adrian},
